<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Fully transparent, no-title Activity theme.
        Used by LockActivity so that no window is visible when locking.
        When an AlertDialog is shown (setup flow), only the dialog itself
        appears over the previous app.
    -->
    <style name="Theme.Transparent" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
