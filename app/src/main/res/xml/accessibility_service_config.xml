<?xml version="1.0" encoding="utf-8"?>
<!--
    Accessibility service configuration.

    This service requires no accessibility events – it only performs the
    GLOBAL_ACTION_LOCK_SCREEN global action when requested by LockActivity.
    Setting accessibilityEventTypes to "0" keeps the permission footprint
    to the absolute minimum.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="0"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagDefault"
    android:canPerformGestures="false"
    android:canRetrieveWindowContent="false"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="0"
    android:settingsActivity="com.lockscreen.app.LockActivity" />
